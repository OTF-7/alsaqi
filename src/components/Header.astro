---
import { Image } from "astro:assets";
import logoLockup from "../assets/alsaqi/logo-lockup.png";
---

<header class="site-header current-header" data-header>
  <div class="header-shell">
    <a class="brand brand-exact" href="#top" aria-label="Al Saqi Mineral Water Factory" data-aria-en="Al Saqi Mineral Water Factory" data-aria-ar="مصنع الساقي للمياه المعدنية">
      <Image src={logoLockup} alt="" width={155} loading="eager" />
      <span class="brand-company">
        <strong data-en="AL SAQI" data-ar="الساقي">AL SAQI</strong>
        <small data-en="MINERAL WATER FACTORY" data-ar="مصنع المياه المعدنية">MINERAL WATER FACTORY</small>
      </span>
    </a>

    <nav class="desktop-nav current-nav" data-nav-order aria-label="Primary navigation" data-aria-en="Primary navigation" data-aria-ar="التنقل الرئيسي">
      <a href="#products" data-en="Water" data-ar="مياهنا">Water</a>
      <a href="#proof" data-en="Proof" data-ar="الجودة">Proof</a>
      <a href="#market" data-en="Market" data-ar="السوق">Market</a>
      <a href="#responsibility" data-en="Responsibility" data-ar="مسؤوليتنا">Responsibility</a>
    </nav>

    <div class="header-actions">
      <div class="lang-switch" role="group" aria-label="Language" data-aria-en="Language" data-aria-ar="اللغة">
        <button type="button" data-lang="en" aria-pressed="true">EN</button>
        <button type="button" data-lang="ar" aria-pressed="false">ع</button>
      </div>
      <a class="header-contact" href="#partners" data-en="Grow with Alsaqi" data-ar="انمُ مع الساقي">Grow with Alsaqi</a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu" data-aria-en="Open menu" data-aria-ar="افتح القائمة"><span></span><span></span></button>
    </div>
  </div>
</header>

<nav class="mobile-menu" id="mobile-menu" data-nav-order aria-label="Mobile navigation" data-aria-en="Mobile navigation" data-aria-ar="تنقل الجوال">
  <a href="#products" data-en="Water" data-ar="مياهنا">Water</a>
  <a href="#proof" data-en="Proof" data-ar="الجودة">Proof</a>
  <a href="#market" data-en="Market" data-ar="السوق">Market</a>
  <a href="#responsibility" data-en="Responsibility" data-ar="مسؤوليتنا">Responsibility</a>
  <a href="#partners" data-en="Grow with Alsaqi" data-ar="انمُ مع الساقي">Grow with Alsaqi</a>
</nav>
