---
import { Image } from "astro:assets";
import folderCover from "../assets/alsaqi-folder-cover.png";
---

<section class="story section" id="story">
  <div class="shell story-grid">
    <div class="story-copy">
      <p class="eyebrow reveal" data-en="WHY AL SAQI" data-ar="لماذا الساقي">WHY AL SAQI</p>
      <h2 class="reveal d1" data-en="Water with a clearer standard." data-ar="مياه بمعيار أكثر صفاءً.">Water with a clearer standard.</h2>
      <p class="lead reveal d2" data-en="Al Saqi Mineral Water Factory brings together careful production, consistent quality and professional distribution to deliver water people can trust and businesses can rely on." data-ar="يجمع مصنع الساقي للمياه المعدنية بين الإنتاج الدقيق والجودة المستمرة والتوزيع الاحترافي لتقديم مياه يثق بها المستهلك ويعتمد عليها الشريك التجاري.">
        Al Saqi Mineral Water Factory brings together careful production, consistent quality and professional distribution to deliver water people can trust and businesses can rely on.
      </p>
      <div class="story-principles">
        <article class="reveal">
          <span>01</span>
          <div><h3 data-en="Quality" data-ar="الجودة">Quality</h3><p data-en="A clean, consistent experience in every bottle." data-ar="تجربة نقية ومتسقة في كل عبوة.">A clean, consistent experience in every bottle.</p></div>
        </article>
        <article class="reveal d1">
          <span>02</span>
          <div><h3 data-en="Continuity" data-ar="الاستمرارية">Continuity</h3><p data-en="Reliable production and supply for growing demand." data-ar="إنتاج وإمداد موثوقان لتلبية الطلب المتنامي.">Reliable production and supply for growing demand.</p></div>
        </article>
        <article class="reveal d2">
          <span>03</span>
          <div><h3 data-en="Trust" data-ar="الثقة">Trust</h3><p data-en="Clear value for consumers, traders and investors." data-ar="قيمة واضحة للمستهلك والتاجر والمستثمر.">Clear value for consumers, traders and investors.</p></div>
        </article>
      </div>
    </div>
    <figure class="story-art reveal d1">
      <Image src={folderCover} alt="Al Saqi blue and green brand identity" widths={[640, 1000, 1400]} sizes="(max-width: 900px) 100vw, 46vw" loading="lazy" />
      <figcaption><strong>2026</strong><span data-en="A new standard begins" data-ar="معيار جديد يبدأ">A new standard begins</span></figcaption>
    </figure>
  </div>
</section>
