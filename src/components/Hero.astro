---
import { Image } from "astro:assets";
import hero from "../assets/alsaqi-hero.png";
---

<section class="hero" id="top">
  <Image
    src={hero}
    alt="Al Saqi mineral water bottles in 330 ml, 750 ml and 1200 ml sizes"
    class="hero-image"
    widths={[768, 1200, 1600, 2200]}
    sizes="100vw"
    fetchpriority="high"
    loading="eager"
  />
  <div class="hero-shade"></div>
  <div class="hero-copy">
    <p class="eyebrow reveal" data-en="NATURAL MINERAL WATER" data-ar="مياه معدنية طبيعية">NATURAL MINERAL WATER</p>
    <h1 class="reveal d1">
      <span data-en="Your refined" data-ar="اختيارك">Your refined</span>
      <em data-en="choice." data-ar="الراقي">choice.</em>
    </h1>
    <p class="hero-tagline reveal d2" data-en="الساقي… اختيارك الراقي" data-ar="الساقي… اختيارك الراقي">الساقي… اختيارك الراقي</p>
    <p class="hero-intro reveal d2" data-en="Pure water, dependable supply, and a bottle made to belong on every table." data-ar="مياه نقية، وإمداد موثوق، وعبوة تليق بكل مائدة.">
      Pure water, dependable supply, and a bottle made to belong on every table.
    </p>
    <div class="hero-actions reveal d3">
      <a class="button button-light" href="#range"><span data-en="Find your size" data-ar="اختر حجمك">Find your size</span><span aria-hidden="true">↓</span></a>
      <a class="text-link" href="#partners" data-en="For trade partners" data-ar="للشركاء التجاريين">For trade partners</a>
    </div>
  </div>
  <div class="hero-proof" aria-label="Product sizes" data-aria-en="Product sizes" data-aria-ar="أحجام المنتجات">
    <span>330 ml</span><span>750 ml</span><span>1200 ml</span>
  </div>
</section>
