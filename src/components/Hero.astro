---
import { Image } from "astro:assets";
import heroArc from "../assets/hero-arc.jpg";
---

<section class="hero" id="top">
  <div class="hero-bg" data-parallax="0.16">
    <div class="ph" data-label="Novan bottles on deep blue"></div>
    <Image
      src={heroArc}
      class="cover"
      alt="Novan bottles arced on deep blue under rays of light"
      fetchpriority="high"
      loading="eager"
      widths={[768, 1280, 1920, 2400]}
      sizes="100vw"
    />
  </div>
  <div class="hero-scrim"></div>

  <div class="hero-inner">
    <span class="kicker hero-kicker reveal" data-en="Saada Highlands · Yemen" data-ar="مرتفعات صعدة · اليمن"
      >Saada Highlands · Yemen</span
    >
    <h1 class="reveal d1">
      <span data-en="A story of passion…" data-ar="قصة شغف...">A story of passion…</span><br />
      <span class="accent" data-en="that quenches every thirst." data-ar="تروي العطش">that quenches every thirst.</span
      >
    </h1>
    <p
      class="hero-sub reveal d2"
      data-en="Drawn from deep mountain aquifers and balanced for a clean, weightless taste — water exactly as nature intended it."
      data-ar="مياه من أعماق الطبقات الجوفية في الجبال، متوازنة المعادن لمذاق نقي وخفيف — هكذا أرادتها الطبيعة تماماً."
    >
      Drawn from deep mountain aquifers and balanced for a clean, weightless taste — water exactly as nature
      intended it.
    </p>
    <div class="hero-cta reveal d3">
      <a href="#range" class="btn btn-light"
        ><span data-en="Explore the range" data-ar="تصفّح المنتجات">Explore the range</span>
        <span class="arrow">→</span></a
      >
      <a href="#films" class="btn btn-outline-light" data-en="Watch the films" data-ar="شاهد الأفلام"
        >Watch the films</a
      >
    </div>
  </div>

  <a
    class="hero-scroll"
    href="#stats"
    aria-label="Scroll to discover"
    data-aria-en="Scroll to discover"
    data-aria-ar="مرّر للاكتشاف">
    <svg class="ring" viewBox="0 0 104 104" aria-hidden="true">
      <defs><path id="ringpath" d="M52,52 m-40,0 a40,40 0 1,1 80,0 a40,40 0 1,1 -80,0"></path></defs>
      <text
        ><textPath href="#ringpath" data-en="SCROLL · DISCOVER" data-ar="مرّر · اكتشف">SCROLL · DISCOVER</textPath
        ></text
      >
    </svg>
    <span class="core">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"
        ><path d="M12 4v16M5 13l7 7 7-7"></path></svg
      >
    </span>
  </a>
</section>
