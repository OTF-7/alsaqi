---
/* Path-style water footer (verified against drinkpathwater.com):
   their wave is an SVG path regenerated every frame (wavify.js) — a
   full-width water surface that undulates in place. We recreate the
   same mechanic in ~30 lines of vanilla TS (see main.ts), with the
   gradient-filled path forming the water body itself. No bottle. */
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
---

<footer class="footer" id="footer">
  <div class="shore" aria-hidden="true">
    <div class="water-label" data-en="Still. Pure. Novan." data-ar="هادئة. نقية. نوفان.">Still. Pure. Novan.</div>
  </div>

  <div class="sea">
    <!-- the water: a living wave drawn by JS; static gentle wave pre-JS -->
    <svg class="sea-svg" viewBox="0 0 1440 600" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="novan-sea-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="oklch(0.58 0.09 245)"></stop>
          <stop offset="0.38" stop-color="oklch(0.42 0.10 255)"></stop>
          <stop offset="1" stop-color="oklch(0.26 0.07 258)"></stop>
        </linearGradient>
      </defs>
      <path
        id="footer-wave"
        fill="url(#novan-sea-grad)"
        d="M 0 604 L 0 40 C 180 40 180 50.91 360 50.91 C 540 50.91 540 37.19 720 37.19 C 900 37.19 900 29.82 1080 29.82 C 1260 29.82 1260 45.44 1440 45.44 L 1440 604 Z"
      ></path>
    </svg>

    <div class="sea-body">
      <div class="wrap">
        <div class="footer-top">
          <div class="footer-brand">
            <div class="brand">
              <Image src={logo} alt="Novan" class="brand-logo" height={168} densities={[1, 2]} loading="lazy" />
            </div>
            <p
              class="footer-blurb"
              data-en="Premium natural water from the Saada highlands — 100% Yemeni, bottled with obsessive care since 2019."
              data-ar="مياه طبيعية فاخرة من مرتفعات صعدة — برأس مال يمني 100%، تُعبّأ بعناية فائقة منذ 2019."
            >
              Premium natural water from the Saada highlands — 100% Yemeni, bottled with obsessive care
              since 2019.
            </p>
          </div>
          <div class="footer-col">
            <h3 data-en="Explore" data-ar="استكشف">Explore</h3>
            <a href="#story" data-en="Our Source" data-ar="مصدرنا">Our Source</a>
            <a href="#range" data-en="The Range" data-ar="منتجاتنا">The Range</a>
            <a href="#films" data-en="Films" data-ar="الأفلام">Films</a>
            <a href="#process" data-en="Purity" data-ar="النقاء">Purity</a>
          </div>
          <div class="footer-col">
            <h3 data-en="Business" data-ar="الأعمال">Business</h3>
            <a href="#contact" data-en="Become a partner" data-ar="كن شريكاً">Become a partner</a>
            <a href="#services" data-en="Our services" data-ar="خدماتنا">Our services</a>
            <a href="#voices" data-en="HoReCa" data-ar="الفنادق والمطاعم">HoReCa</a>
          </div>
          <div class="footer-col">
            <h3 data-en="Contact" data-ar="تواصل">Contact</h3>
            <p data-en="Saada, Yemen" data-ar="صعدة، اليمن">Saada, Yemen</p>
            <a href="mailto:water.novan@gmail.com">water.novan@gmail.com</a>
            <a href="tel:+967776962020"><bdi dir="ltr">+967 776 962 020</bdi></a>
            <a href="tel:+967773156374"><bdi dir="ltr">+967 773 156 374</bdi></a>
            <a href="tel:+967717011011"><bdi dir="ltr">+967 717 011 011</bdi></a>
            <a href="tel:+9677533353"><bdi dir="ltr">+967 7 533 353</bdi></a>
          </div>
        </div>
        <div class="footer-bottom">
          <span
            data-en="All rights reserved to Al-Romana Foundation for Advertising & Marketing — Digital Marketing & Multimedia Division, 2026"
            data-ar="جميع الحقوق محفوظه لدى مؤسسة الرمانة للدعاية والإعلان قطاع التسويق الإلكتروني والملتيميديا 2026"
            >All rights reserved to Al-Romana Foundation for Advertising & Marketing — Digital Marketing &
            Multimedia Division, 2026</span
          >
          <div class="footer-social">
            <a
              href="https://www.instagram.com/novan.water"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              ><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                ><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"
                ></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle></svg
              ></a
            >
            <a
              href="https://www.facebook.com/people/%D9%85%D9%8A%D8%A7%D9%87-%D9%86%D9%88%D9%81%D8%A7%D9%86-NOVAN-WATER/61550649026151"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
              ><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                ><path d="M15 3h-3a4 4 0 00-4 4v3H5v4h3v7h4v-7h3l1-4h-4V7a1 1 0 011-1h3z"></path></svg
              ></a
            >
            <a href="https://x.com/NOVANWATER" target="_blank" rel="noopener noreferrer" aria-label="X"
              ><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
                ><path d="M18 2h3l-7 8 8 12h-6l-5-7-5 7H3l8-9L3 2h6l4 6z"></path></svg
              ></a
            >
            <a
              href="https://www.youtube.com/@novanwater"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="YouTube"
              ><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                ><rect x="2.5" y="5.5" width="19" height="13" rx="4"></rect><path
                  d="M10.2 9.4l4.8 2.6-4.8 2.6z"
                  fill="currentColor"
                  stroke="none"></path></svg
              ></a
            >
            <a
              href="https://www.tiktok.com/@novan.water"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
              ><svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor"
                ><path
                  d="M10.511 1.705h2.74s-.157 3.51 3.795 3.768v2.711s-2.114.129-3.796-1.158l.028 5.606A5.073 5.073 0 1 1 8.213 7.56h.708v2.785a2.298 2.298 0 1 0 1.618 2.205L10.51 1.705Z"
                ></path></svg
              ></a
            >
            <a
              href="https://www.snapchat.com/add/novanwater"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Snapchat"
              ><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
                ><path
                  d="M12 3.2c2.4 0 4.3 1.9 4.4 4.3l.06 1.5c.45.18.9-.18 1.4-.18.55 0 1 .36 1 .82 0 .73-1.1.95-1.75 1.4-.27.18-.36.45-.27.73.55 1.4 1.75 2.4 3 2.7.36.1.55.36.45.64-.18.64-1.5.95-2.4 1.1-.18 0-.27.18-.36.45-.1.36-.18.73-.55.73-.45 0-1-.27-1.85-.27-.55 0-.9.18-1.4.55-.64.55-1.4 1.1-2.5 1.1s-1.85-.55-2.5-1.1c-.45-.36-.82-.55-1.4-.55-.82 0-1.4.27-1.85.27-.36 0-.45-.36-.55-.73-.1-.27-.18-.45-.36-.45-.9-.18-2.2-.45-2.4-1.1-.1-.27.1-.55.45-.64 1.3-.27 2.5-1.3 3-2.7.1-.27 0-.55-.27-.73-.64-.45-1.75-.64-1.75-1.4 0-.45.45-.82 1-.82.45 0 .95.36 1.4.18l.06-1.5C7.7 5.1 9.6 3.2 12 3.2Z"
                ></path></svg
              ></a
            >
          </div>
        </div>
      </div>
      <div class="sea-name" data-en="NOVAN" data-ar="نوفان" aria-hidden="true">NOVAN</div>
    </div>
  </div>
</footer>
