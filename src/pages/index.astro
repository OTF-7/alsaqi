---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Story from "../components/Story.astro";
import Range from "../components/Range.astro";
import Vision from "../components/Vision.astro";
import Process from "../components/Process.astro";
import Market from "../components/Market.astro";
import Sustain from "../components/Sustain.astro";
import Cta from "../components/Cta.astro";
import WaterFooter from "../components/WaterFooter.astro";
import WhatsApp from "../components/WhatsApp.astro";
---

<Base
  title="Al Saqi Mineral Water Factory | Your refined choice"
  description="Al Saqi natural mineral water in 330 ml, 750 ml and 1200 ml bottles. Quality, reliable supply and a refined choice for consumers and trade partners."
>
  <Header />
  <main>
    <Hero />
    <Story />
    <Range />
    <Vision />
    <Process />
    <Market />
    <Sustain />
    <Cta />
  </main>
  <WaterFooter />
  <WhatsApp />
</Base>
